# 本地开发环境配置示例
# 复制此文件为 .env 并填入真实值

# ========== 基础配置 ==========
DEBUG=true
SECRET_KEY=your-production-secret-key-here
DB_PASSWORD=your-production-db-password-here
# 生产环境保持 false；如需本地启动时自动迁移/种子，可显式改为 true。
AUTO_MIGRATE_ON_STARTUP=false
AUTO_SEED_ON_STARTUP=false
# REDIS_PASSWORD=
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ========== 腾讯 IM 配置 ==========
# 腾讯云 IM 应用 ID（在腾讯云 IM 控制台 https://console.cloud.tencent.com/im 获取）
IM_SDKAPPID=1400xxxxxx
# 腾讯云 IM 密钥（用于生成 UserSig）
IM_SECRETKEY=xxxxxxxx
